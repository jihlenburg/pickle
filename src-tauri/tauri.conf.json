{
  "$schema": "https://raw.githubusercontent.com/nicotsx/tauri-v2-schema/main/tauri.conf.json",
  "productName": "pickle",
  "version": "0.1.0",
  "identifier": "com.github.jihlenburg.pickle",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "pickle — Pin Configurator",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
